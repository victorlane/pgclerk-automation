{{ ansible_managed | comment }}
PGCLERK_SERVER_URL={{ konnectivity_server_url }}
PGCLERK_MODE={{ konnectivity_mode }}
PGCLERK_CLUSTER={{ konnectivity_cluster }}
PGCLERK_BOOTSTRAP_TOKEN={{ konnectivity_bootstrap_token }}
PGCLERK_TOKEN_FILE={{ konnectivity_conf_dir }}/token
PGCLERK_PROBE_INTERVAL={{ konnectivity_probe_interval }}
PGCLERK_SNAPSHOT_INTERVAL={{ konnectivity_snapshot_interval }}
{% if konnectivity_ntp_host | length > 0 %}
PGCLERK_NTP_HOST={{ konnectivity_ntp_host }}
{% endif %}
{% if konnectivity_labels | length > 0 %}
PGCLERK_LABELS={{ konnectivity_labels }}
{% endif %}
{% if konnectivity_mode == 'worker' %}
PGCLERK_WORKER_PROBE={{ konnectivity_worker_probe }}
{% endif %}
PGCLERK_ALLOW_EXEC={{ konnectivity_allow_exec }}
PGCLERK_ALLOW_EXEC_CMDS={{ konnectivity_allow_exec_cmds }}
